    <groupId>com.guicedee.modules.services</groupId>
    <artifactId>vertx-mutiny</artifactId>

    <name>Vert.x Mutiny</name>
    <packaging>jar</packaging>

    <properties>
        <project.scm.nameUrl>/GuicedEE/Services/Vert.x/vertx-mutiny</project.scm.nameUrl>
    </properties>

    <version>2.0.0-RC8</version>

    <licenses>
        <license>
            <name>Apache License, Version 2.0</name>
            <url>http://www.apache.org/licenses/LICENSE-2.0.txt</url>
            <distribution>repo</distribution>
        </license>
    </licenses>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <executions>
                    <execution>
                        <id>shade</id>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <keepDependenciesWithProvidedScope>false</keepDependenciesWithProvidedScope>
                            <promoteTransitiveDependencies>false</promoteTransitiveDependencies>
                            <artifactSet>
                                <includes>
                                    <include>io.smallrye.reactive:*vertx*:*</include>
                                    <include>io.smallrye.reactive:mutiny-smallrye-context-propagation:*</include>
                                    <include>io.smallrye:smallrye-context-propagation*:*</include>
                                </includes>
                            </artifactSet>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <executions>
                    <execution>
                        <id>remove-removed-pool-sources</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <!-- Pool classes removed in Vert.x 5 -->
                                <delete file="target/source-output/io/vertx/mutiny/mssqlclient/MSSQLPool.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/mysqlclient/MySQLPool.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/db2client/DB2Pool.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/oracleclient/OraclePool.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/pgclient/PgPool.java" failonerror="false"/>
                                <!-- CLI package removed in Vert.x 5 -->
                                <delete dir="target/source-output/io/vertx/mutiny/core/cli" failonerror="false"/>
                                <!-- SmallRye context propagation referencing MicroProfile Config -->
                                <delete dir="target/source-output/io/smallrye/context/impl" failonerror="false"/>
                                <!-- Web client predicate removed in Vert.x 5 -->
                                <delete dir="target/source-output/io/vertx/mutiny/ext/web/client/predicate" failonerror="false"/>
                                <!-- Auth modules referencing removed APIs -->
                                <delete dir="target/source-output/io/vertx/mutiny/ext/auth/htdigest" failonerror="false"/>
                                <delete dir="target/source-output/io/vertx/mutiny/ext/auth/jwt" failonerror="false"/>
                                <delete dir="target/source-output/io/vertx/mutiny/ext/auth/oauth2" failonerror="false"/>
                                <delete dir="target/source-output/io/vertx/mutiny/ext/auth/otp" failonerror="false"/>
                                <delete dir="target/source-output/io/vertx/mutiny/ext/auth/webauthn" failonerror="false"/>
                                <!-- Core classes referencing removed Vert.x 5 APIs -->
                                <delete file="target/source-output/io/vertx/mutiny/core/http/HttpClient.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/core/http/HttpHeaders.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/core/streams/Pump.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/core/TimeoutStream.java" failonerror="false"/>
                                <delete file="target/source-output/io/smallrye/mutiny/vertx/core/ContextAwareExecutorWrapper.java" failonerror="false"/>
                                <!-- Auth classes referencing removed APIs -->
                                <delete file="target/source-output/io/vertx/mutiny/ext/auth/AuthProvider.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/ext/auth/HashingAlgorithm.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/ext/auth/HashingStrategy.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/ext/auth/VertxContextPRNG.java" failonerror="false"/>
                                <!-- Web handler/client classes referencing removed APIs -->
                                <delete file="target/source-output/io/vertx/mutiny/ext/web/client/OAuth2WebClient.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/ext/web/handler/DigestAuthHandler.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/ext/web/handler/JWTAuthHandler.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/ext/web/handler/OAuth2AuthHandler.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/ext/web/handler/OtpAuthHandler.java" failonerror="false"/>
                                <delete file="target/source-output/io/vertx/mutiny/ext/web/handler/WebAuthnHandler.java" failonerror="false"/>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.moditect</groupId>
                <artifactId>moditect-maven-plugin</artifactId>
            </plugin>

            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>flatten-maven-plugin</artifactId>
            </plugin>

            <plugin>
                <groupId>com.coderplus.maven.plugins</groupId>
                <artifactId>copy-rename-maven-plugin</artifactId>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-javadoc-plugin</artifactId>
                <inherited>true</inherited>
                <configuration>
                    <additionalDependencies>
