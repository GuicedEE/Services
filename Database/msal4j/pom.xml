<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.guicedee</groupId>
        <artifactId>parent</artifactId>
        <version>2.0.3-SNAPSHOT</version>
    </parent>

    <groupId>com.guicedee.modules.services</groupId>
    <artifactId>azure-identity</artifactId>
    <version>2.0.3-SNAPSHOT</version>
    <name>azure-identity</name>

    <properties>
        <project.scm.nameUrl>/GuicedEE/Services</project.scm.nameUrl>
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <executions>
                    <execution>
                        <id>shade</id>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <artifactSet>
                                <includes>
                                    <include>com.azure</include>
                                    <include>com.nimbusds</include>
                                    <include>com.microsoft.azure</include>
                                    <include>com.microsoft.aad</include>
                                    <include>org.simpleframework</include>
                                    <include>io.netty</include>
                                    <include>io.projectreactor</include>
                                    <include>org.reactivestreams</include>
                                    <include>net.minidev</include>
                                    <include>xpp3</include>
                                    <include>io.projectreactor.netty</include>
                                    <include>org.linguafranca.pwdb:*</include>
                                    <include>com.madgag.spongycastle</include>
                                    <include>com.github.stephenc.jcip:*</include>
                                </includes>
                            </artifactSet>
                            <relocations>

                            </relocations>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <executions>
                    <execution>
                        <id>remove-broken-shaded-sources</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <!-- Netty optional codec/compression deps -->
                                <delete file="target/source-output/io/netty/handler/codec/compression/LzfDecoder.java" failonerror="false"/>
                                <delete file="target/source-output/io/netty/handler/codec/compression/LzfEncoder.java" failonerror="false"/>
                                <delete file="target/source-output/io/netty/handler/codec/compression/LzmaFrameEncoder.java" failonerror="false"/>
                                <delete file="target/source-output/io/netty/handler/codec/compression/ZstdConstants.java" failonerror="false"/>
                                <delete file="target/source-output/io/netty/handler/codec/compression/ZstdDecoder.java" failonerror="false"/>
                                <delete file="target/source-output/io/netty/handler/codec/compression/ZstdEncoder.java" failonerror="false"/>
                                <!-- Netty optional SSL/SVM/logging -->
                                <delete file="target/source-output/io/netty/handler/ssl/util/CertificateBuilderCertGenerator.java" failonerror="false"/>
                                <delete file="target/source-output/io/netty/util/internal/Hidden.java" failonerror="false"/>
                                <delete dir="target/source-output/io/netty/util/internal/logging" failonerror="false"/>
                                <delete dir="target/source-output/io/netty/util/internal/svm" failonerror="false"/>
                                <delete file="target/source-output/io/netty/util/NetUtilSubstitutions.java" failonerror="false"/>
                                <!-- Reactor optional deps -->
                                <delete file="target/source-output/reactor/core/publisher/Traces.java" failonerror="false"/>
                                <delete file="target/source-output/reactor/core/scheduler/ReactorBlockHoundIntegration.java" failonerror="false"/>
                                <delete file="target/source-output/reactor/netty/contextpropagation/ChannelContextAccessor.java" failonerror="false"/>
                                <delete file="target/source-output/reactor/netty/http/server/NonSslRedirectDetector.java" failonerror="false"/>
                                <delete file="target/source-output/reactor/netty/http/server/NonSslRedirectHandler.java" failonerror="false"/>
                                <delete file="target/source-output/reactor/netty/resources/DefaultLoopIOUring.java" failonerror="false"/>
                                <delete file="target/source-output/reactor/util/package-info.java" failonerror="false"/>
                                <!-- OpenSAML -->
                                <delete file="target/source-output/com/nimbusds/oauth2/sdk/assertions/saml2/SAML2AssertionValidator.java" failonerror="false"/>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.moditect</groupId>
                <artifactId>moditect-maven-plugin</artifactId>
            </plugin>

            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>flatten-maven-plugin</artifactId>
            </plugin>

            <plugin>
                <groupId>com.coderplus.maven.plugins</groupId>
                <artifactId>copy-rename-maven-plugin</artifactId>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-javadoc-plugin</artifactId>
                <configuration>
                    <additionalDependencies>
                        <!-- reactor-pool (reactor.pool, reactor.pool.decorators, reactor.pool.introspection) -->
                        <additionalDependency>
                            <groupId>io.projectreactor.addons</groupId>
                            <artifactId>reactor-pool</artifactId>
                            <version>1.0.6</version>
                        </additionalDependency>
                        <!-- micrometer (io.micrometer.core.instrument) -->
                        <additionalDependency>
                            <groupId>io.micrometer</groupId>
                            <artifactId>micrometer-core</artifactId>
                            <version>1.12.5</version>
                        </additionalDependency>
                        <!-- google tink (com.google.crypto.tink.subtle) -->
                        <additionalDependency>
                            <groupId>com.google.crypto.tink</groupId>
                            <artifactId>tink</artifactId>
                            <version>1.12.0</version>
                        </additionalDependency>
                        <!-- bouncycastle FIPS (org.bouncycastle.jcajce.provider) -->
                        <additionalDependency>
                            <groupId>org.bouncycastle</groupId>
                            <artifactId>bc-fips</artifactId>
                            <version>1.0.2.5</version>
                        </additionalDependency>
                        <!-- opensaml core (org.opensaml.core.*) -->
                        <additionalDependency>
                            <groupId>org.opensaml</groupId>
                            <artifactId>opensaml-core</artifactId>
                            <version>4.3.0</version>
                        </additionalDependency>
                        <!-- opensaml SAML API (org.opensaml.saml.saml2.core) -->
                        <additionalDependency>
                            <groupId>org.opensaml</groupId>
                            <artifactId>opensaml-saml-api</artifactId>
                            <version>4.3.0</version>
                        </additionalDependency>
                        <!-- opensaml security API (org.opensaml.security.credential) -->
                        <additionalDependency>
                            <groupId>org.opensaml</groupId>
                            <artifactId>opensaml-security-api</artifactId>
                            <version>4.3.0</version>
                        </additionalDependency>
                        <!-- opensaml xmlsec API (org.opensaml.xmlsec.signature, org.opensaml.xmlsec.signature.support) -->
                        <additionalDependency>
                            <groupId>org.opensaml</groupId>
                            <artifactId>opensaml-xmlsec-api</artifactId>
                            <version>4.3.0</version>
                        </additionalDependency>
                        <!-- joda-time (org.joda.time) -->
                        <additionalDependency>
                            <groupId>joda-time</groupId>
                            <artifactId>joda-time</artifactId>
                            <version>2.12.7</version>
                        </additionalDependency>
                        <!-- shibboleth java-support (net.shibboleth.utilities.java.support.xml) -->
                        <additionalDependency>
                            <groupId>net.shibboleth.utilities</groupId>
                            <artifactId>java-support</artifactId>
                            <version>8.4.2</version>
                        </additionalDependency>
                        <!-- jzlib (com.jcraft.jzlib) -->
                        <additionalDependency>
                            <groupId>com.jcraft</groupId>
                            <artifactId>jzlib</artifactId>
                            <version>1.1.3</version>
                        </additionalDependency>
                        <!-- lz4 (net.jpountz.lz4) -->
                        <additionalDependency>
                            <groupId>net.jpountz.lz4</groupId>
                            <artifactId>lz4</artifactId>
                            <version>1.3.0</version>
                        </additionalDependency>
                        <!-- siv-mode (org.cryptomator.siv) -->
                        <additionalDependency>
                            <groupId>org.cryptomator</groupId>
                            <artifactId>siv-mode</artifactId>
                            <version>1.5.2</version>
                        </additionalDependency>
                        <additionalDependency>
                            <groupId>org.opensaml</groupId>
                            <artifactId>opensaml-saml-impl</artifactId>
                            <version>4.3.0</version>
                        </additionalDependency>
                        <additionalDependency>
                            <groupId>jakarta.annotation</groupId>
                            <artifactId>jakarta.annotation-api</artifactId>
                            <version>3.0.0</version>
                        </additionalDependency>
                    </additionalDependencies>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <dependencies>
        <dependency>
            <groupId>com.azure</groupId>
            <artifactId>azure-identity</artifactId>
            <version>1.12.2</version>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>com.microsoft.azure</groupId>
            <artifactId>msal4j</artifactId>
