<?xml version="1.0" encoding="utf-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://maven.apache.org/POM/4.0.0" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.guicedee</groupId>
        <artifactId>parent</artifactId>
        <version>2.1.1-SNAPSHOT</version>
    </parent>
    <groupId>com.guicedee.modules.services</groupId>
    <artifactId>testcontainers</artifactId>
    <name>testcontainers</name>
    <version>2.1.1-SNAPSHOT</version>
    <packaging>jar</packaging>
    <description>
        A modularized test containers implementation
    </description>
    <properties>
        <project.scm.nameUrl>/GuicedEE/Services</project.scm.nameUrl>
    </properties>
    <url>https://guicedee.com</url>
    <dependencies>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-postgresql</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-mysql</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-mariadb</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-mssqlserver</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-oracle-free</artifactId>
            <version>${testcontainers.oraclefree.version}</version>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-mongodb</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-cassandra</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-clickhouse</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-cockroachdb</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-rabbitmq</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-kafka</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-elasticsearch</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-nginx</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-jdbc</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-r2dbc</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-junit-jupiter</artifactId>
            <scope>compile</scope>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>com.guicedee.modules.services</groupId>
            <artifactId>jna-platform</artifactId>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-core</artifactId>
        </dependency>
        <dependency>
            <groupId>commons-codec</groupId>
            <artifactId>commons-codec</artifactId>
        </dependency>
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-compress</artifactId>
        </dependency>
        <dependency>
            <groupId>commons-io</groupId>
            <artifactId>commons-io</artifactId>
        </dependency>
        <dependency>
            <groupId>com.github.docker-java</groupId>
            <artifactId>docker-java-api</artifactId>
            <version>${docker.java.version}</version>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>com.github.docker-java</groupId>
            <artifactId>docker-java-transport-zerodep</artifactId>
            <version>${docker.java.version}</version>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.rnorth.duct-tape</groupId>
            <artifactId>duct-tape</artifactId>
            <version>${duct.tape.version}</version>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>
        <dependency>
            <groupId>junit</groupId>
            <artifactId>junit</artifactId>
            <version>${junit.version}</version>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>com.google.guava</groupId>
            <artifactId>guava</artifactId>
        </dependency>
        <dependency>
            <groupId>jakarta.annotation</groupId>
            <artifactId>jakarta.annotation-api</artifactId>
        </dependency>
        <dependency>
            <groupId>com.guicedee.modules.services</groupId>
            <artifactId>reactive-streams</artifactId>
            <version>${project.version}</version>
        </dependency>
    </dependencies>
    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <executions>
                    <execution>
                        <id>shade</id>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <artifactSet>
                                <includes>
                                    <!--<include>org.opentest4j:*</include>-->
                                    <!--<include>org.apiguardian:*</include>-->
                                    <!--<include>org.junit.platform:*</include>
                                    <include>org.junit.jupiter:*</include>
                                    <include>org.junit.vintage:*</include>
                                    <include>junit:*</include>
                                    -->
                                    <include>org.testcontainers:*</include>
                                    <include>io.r2dbc</include>
                                    <include>org.rnorth.duct-tape:*</include>
                                    <include>com.github.docker-java:*</include>
                                </includes>
                            </artifactSet>
                            <filters>
                                <filter>
                                    <artifact>org.testcontainers:*</artifact>
                                    <excludes>
                                        <exclude>org/reactivestreams/**</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <executions>
                    <execution>
                        <id>remove-broken-shaded-sources</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <!-- docker-java transport/shaded sources -->
                                <delete dir="target/source-output/com/github/dockerjava/transport" failonerror="false" />
                                <delete dir="target/source-output/com/github/dockerjava/zerodep" failonerror="false" />
                                <delete file="target/source-output/com/github/dockerjava/api/command/PushImageCmd.java" failonerror="false" />
                                <!-- jib sources -->
                                <delete dir="target/source-output/org/testcontainers/jib" failonerror="false" />
                                <!-- r2dbc sources -->
                                <delete dir="target/source-output/org/testcontainers/r2dbc" failonerror="false" />
                                <delete file="target/source-output/org/testcontainers/containers/PostgreSQLR2DBCDatabaseContainerProvider.java" failonerror="false" />
                                <!-- Network uses @Value from immutables generating inner classes -->
                                <delete file="target/source-output/org/testcontainers/containers/Network.java" failonerror="false" />
                                <!-- JUnit Jupiter extension sources -->
                                <delete dir="target/source-output/org/testcontainers/junit" failonerror="false" />
                                <!-- PostgreSQL R2DBC -->
                                <delete dir="target/source-output/org/testcontainers/postgresql" failonerror="false" />
                                <!-- Additional database module sources that may break -->
                                <delete file="target/source-output/org/testcontainers/containers/MySQLR2DBCDatabaseContainerProvider.java" failonerror="false" />
                                <delete file="target/source-output/org/testcontainers/containers/MariaDBR2DBCDatabaseContainerProvider.java" failonerror="false" />
                                <delete file="target/source-output/org/testcontainers/containers/MSSQLServerR2DBCDatabaseContainerProvider.java" failonerror="false" />
                                <delete file="target/source-output/org/testcontainers/containers/OracleR2DBCDatabaseContainerProvider.java" failonerror="false" />
                                <delete dir="target/source-output/org/testcontainers/elasticsearch" failonerror="false" />
                                <delete dir="target/source-output/org/testcontainers/kafka" failonerror="false" />
                                <!-- R2DBC sources that import vendor-specific R2DBC drivers not on classpath -->
                                <delete file="target/source-output/org/testcontainers/clickhouse/ClickHouseR2DBCDatabaseContainerProvider.java" failonerror="false" />
                                <delete file="target/source-output/org/testcontainers/containers/MSSQLR2DBCDatabaseContainerProvider.java" failonerror="false" />
                                <delete file="target/source-output/org/testcontainers/mariadb/MariaDBR2DBCDatabaseContainer.java" failonerror="false" />
                                <delete file="target/source-output/org/testcontainers/mssqlserver/MSSQLR2DBCDatabaseContainer.java" failonerror="false" />
                                <delete file="target/source-output/org/testcontainers/mysql/MySQLR2DBCDatabaseContainer.java" failonerror="false" />
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.moditect</groupId>
                <artifactId>moditect-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>flatten-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>com.coderplus.maven.plugins</groupId>
                <artifactId>copy-rename-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-javadoc-plugin</artifactId>
                <configuration>
                    <additionalDependencies>
                        <additionalDependency>
                            <groupId>com.github.docker-java</groupId>
                            <artifactId>docker-java-core</artifactId>
                            <version>3.4.1</version>
                        </additionalDependency>
                        <additionalDependency>
                            <groupId>org.yaml</groupId>
                            <artifactId>snakeyaml</artifactId>
                            <version>2.3</version>
                        </additionalDependency>
                        <additionalDependency>
                            <groupId>com.trilead</groupId>
                            <artifactId>trilead-ssh2</artifactId>
                            <version>1.0.0-build222</version>
                        </additionalDependency>
                        <additionalDependency>
                            <groupId>org.zeroturnaround</groupId>
                            <artifactId>zt-exec</artifactId>
                            <version>1.12</version>
                        </additionalDependency>
                        <additionalDependency>
                            <groupId>org.awaitility</groupId>
                            <artifactId>awaitility</artifactId>
                            <version>4.2.2</version>
                        </additionalDependency>
                        <additionalDependency>
                            <groupId>org.immutables</groupId>
                            <artifactId>value</artifactId>
                            <version>2.10.1</version>
                        </additionalDependency>
                        <additionalDependency>
                            <groupId>org.jetbrains</groupId>
                            <artifactId>annotations</artifactId>
                            <version>26.0.2</version>
                        </additionalDependency>
                    </additionalDependencies>
                </configuration>
            </plugin>
        </plugins>
    </build>
    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.guicedee</groupId>
                <artifactId>standalone-bom</artifactId>
                <version>${guicedee.version}</version>
                <scope>import</scope>
                <type>pom</type>
            </dependency>
            <dependency>
                <groupId>com.guicedee</groupId>
                <artifactId>tests-bom</artifactId>
                <version>${guicedee.version}</version>
                <scope>import</scope>
                <type>pom</type>
            </dependency>
        </dependencies>
    </dependencyManagement>
</project>
